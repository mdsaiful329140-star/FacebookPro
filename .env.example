# Required
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/facebook_pro?schema=public"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="please-change-this-to-a-long-random-value"

# NextAuth - Google (placeholders)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# NextAuth - Email provider SMTP (for magic link)
EMAIL_SERVER="smtp://user:pass@smtp.example.com:587"
EMAIL_FROM="no-reply@example.com"

# Optional: S3 config for later image uploads
AWS_S3_BUCKET=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION=""
